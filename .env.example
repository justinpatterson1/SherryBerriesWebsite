# Neon PostgreSQL — copy this file to .env and fill in.
# Prisma 7 dropped `directUrl`; use a single connection string for both
# runtime queries (via PrismaPg adapter) AND `prisma migrate`. Use Neon's
# *unpooled* connection string (PrismaPg manages its own pool).
# Get it from: Neon dashboard → your project → Connection Details → Direct.

DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# NextAuth v5 — credentials provider only.
# Generate AUTH_SECRET with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# AUTH_URL is inferred at runtime in dev; set explicitly in production.
AUTH_SECRET=

# Resend (transactional email — verification links).
# Get an API key at https://resend.com/api-keys.
# EMAIL_FROM must be on a domain you've verified in Resend. The default test
# sender (onboarding@resend.dev) only delivers to your own Resend account email.
RESEND_API_KEY=
EMAIL_FROM="SherryBerries <onboarding@resend.dev>"

# Cloudinary (added later)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# WiPay (added later)
# WIPAY_API_KEY=

# NEXT_PUBLIC_SITE_URL=http://localhost:3000
