# Neon PostgreSQL — copy this file to .env and fill in.
# Prisma 7 dropped `directUrl`; use a single connection string for both
# runtime queries (via PrismaPg adapter) AND `prisma migrate`. Use Neon's
# *unpooled* connection string (PrismaPg manages its own pool).
# Get it from: Neon dashboard → your project → Connection Details → Direct.

DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=verify-full

# NextAuth v5 — credentials provider only.
# Generate AUTH_SECRET with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# AUTH_URL is inferred at runtime in dev; set explicitly in production.
AUTH_SECRET=

# Resend (transactional email — verification links).
# Get an API key at https://resend.com/api-keys.
# EMAIL_FROM must be on a domain you've verified in Resend. The default test
# sender (onboarding@resend.dev) only delivers to your own Resend account email.
RESEND_API_KEY=
EMAIL_FROM="SherryBerries <onboarding@resend.dev>"

# Upstash Redis (rate limiting on auth endpoints, via @upstash/ratelimit).
# Create a database at https://console.upstash.com → REST API → copy the URL +
# token. Optional: if unset, auth rate limiting "fails open" (requests allowed).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudinary (added later)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# WiPay (Plugins Payment Request API — card payments at checkout).
# Docs: docs/Payments API Documentation v1.0.8.pdf
#
# WIPAY_ENVIRONMENT switches between the test gateway and real charges:
#   - "sandbox" (default): the WiPay TEST account is used automatically
#     (account 1234567890, API Key 123) — leave the credentials below blank and
#     pay with the doc's test cards (e.g. 5111111111111111 = approved).
#   - "live": you MUST set WIPAY_ACCOUNT_NUMBER + WIPAY_API_KEY to your verified
#     WiPay Business Account's values (from the Developer section of your WiPay
#     dashboard). Keep the API Key secret — it signs the transaction hash.
WIPAY_ENVIRONMENT=sandbox
WIPAY_ACCOUNT_NUMBER=
WIPAY_API_KEY=
# Optional overrides (defaults shown). country/currency must match your account.
# WIPAY_COUNTRY_CODE=TT          # BB | GY | JM | TT
# WIPAY_CURRENCY=TTD             # JMD | TTD | USD
# WIPAY_FEE_STRUCTURE=merchant_absorb   # customer_pay | merchant_absorb | split
# WIPAY_ORIGIN=SherryBerries     # 1–32 chars, your app identifier

# Public site origin — used to build the WiPay response_url (the page WiPay
# redirects the payor back to). Defaults to the request origin if unset; set it
# explicitly in production. In local dev http://localhost:3000 works because the
# redirect happens in the payor's own browser.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudflare R2 (S3-compatible) — powers admin product-image uploads.
# All five must be set for the admin "Upload image" button to work; when unset,
# the upload endpoint returns 503 and admins can still paste an image URL.
# R2_PUBLIC_URL is the bucket's public base (custom domain or pub-xxxx.r2.dev);
# its host is auto-added to next.config's image remotePatterns.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://pub-xxxx.r2.dev